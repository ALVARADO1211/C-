#include <iostream>

using namespace std;

int arreglo[5]; //CONTAR NUMEROS MAYORES A 4
int cont = 0;

int main()
{
    for(int x=0; x<5; x++)
    {
        cout<<"INGRESA UN NUMERO : "; cin>>arreglo[x];
        
        if(arreglo[x] > 4)
        {
            cont++;
        }
    }
    
    if(cont > 0)
    {
       cout<<"LOS NUMEROS MAYORES A 4 SON => "<<cont;
    }
    
    else
    {
        cout<<"NO SE INGRESARON NUMEROS MAYORES A 4";
    }
    
    return 0;
}
